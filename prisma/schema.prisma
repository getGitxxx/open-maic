generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id            String                  @id @default(cuid())
  email         String                  @unique
  passwordHash  String                  @map("password_hash")
  name          String?
  image         String?
  emailVerified DateTime?               @map("email_verified")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")
  classrooms         Classroom[]
  resetTokens        PasswordResetToken[]
  activationTokens   EmailActivationToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model EmailActivationToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_activation_tokens")
}

model Classroom {
  id           String        @id
  userId       String?       @map("user_id")
  title        String?
  requirement  String?       @map("requirement")
  status       String        @default("completed")
  stageData    Json?         @map("stage_data")
  thumbnailUrl String?       @map("thumbnail_url")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  user         User?         @relation(fields: [userId], references: [id])
  scenes       Scene[]
  mediaFiles   MediaFile[]

  @@index([userId])
  @@map("classrooms")
}

model Scene {
  id          String   @id
  classroomId String   @map("classroom_id")
  order       Int
  type        String?
  title       String?
  content     Json
  actions     Json?
  whiteboard  Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([classroomId])
  @@map("scenes")
}

model MediaFile {
  id          String   @id
  classroomId String   @map("classroom_id")
  sceneId     String?  @map("scene_id")
  type        String   // 'audio' | 'image' | 'video'
  blobUrl     String   @map("blob_url")
  mimeType    String?  @map("mime_type")
  size        Int?
  prompt      String?
  createdAt   DateTime @default(now()) @map("created_at")
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([classroomId])
  @@map("media_files")
}

model ClassroomGenerationJob {
  id              String   @id
  status          String   @default("queued")
  step            String   @default("queued")
  progress        Int      @default(0)
  message         String?
  userId          String?  @map("user_id")
  requirement     String?  @db.VarChar(500)
  result          Json?
  error           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")

  @@index([userId])
  @@index([status])
  @@map("classroom_generation_jobs")
}